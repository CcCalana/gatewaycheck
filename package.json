  ],
  "keywords": [
    "ai",
    "llm",
    "gateway",
    "gatewaycheck",
    "benchmark",
    "relay",
    "proxy",
    "openai",
    "anthropic",
    "gemini",
    "cli",
    "audit"
  ],
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CcCalana/gatewaycheck.git"
  },
  "bugs": {
    "url": "https://github.com/CcCalana/gatewaycheck/issues"
  },
  "homepage": "https://github.com/CcCalana/gatewaycheck#readme",
  "scripts": {
    "gatewaycheck": "node packages/cli/bin/gatewaycheck.mjs",
    "gc": "node packages/cli/bin/gatewaycheck.mjs",
    "gb": "node packages/cli/bin/gatewaycheck.mjs",
    "init": "node packages/cli/bin/gatewaycheck.mjs init",
    "discover": "node packages/cli/bin/gatewaycheck.mjs discover",
    "agent": "node packages/cli/bin/gatewaycheck.mjs agent",
    "cache": "node packages/cli/bin/gatewaycheck.mjs cache",
